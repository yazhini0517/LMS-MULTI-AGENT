# ============================================================
#   Multi-Agent Tutorial Generation System
#   Environment Configuration (Ollama Version)
#   Copy this file to .env and update values as needed
#   cp .env.example .env
# ============================================================


# ------------------------------------------------------------
# DATABASE SETTINGS
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=55432
DB_NAME=lms_db
DB_USER=postgres
DB_PASSWORD=my_password


# ------------------------------------------------------------
# OLLAMA SETTINGS
# ------------------------------------------------------------
# Pull the model before running: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434


# ------------------------------------------------------------
# RAG SYSTEM SETTINGS
# ------------------------------------------------------------
# Must be running before starting this multi-agent system
RAG_SERVER_URL=http://localhost:8002


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO